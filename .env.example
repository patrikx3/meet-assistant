# Meet Assistant — example environment file.
#
# Copy this file to `.env` in the project root and add your OpenAI key.
#
#   cp .env.example .env
#
# `.env` is gitignored and never committed.

# OpenAI GPT-4o Transcribe — the only transcription engine used.
# Get a key: https://platform.openai.com/api-keys
OPENAI_API_KEY=
